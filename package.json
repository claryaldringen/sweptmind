{
  "name": "sweptmind",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.6.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "next dev --turbopack -p 3006",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "yarn lint && yarn format:check && yarn typecheck && yarn test",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@apollo/client-integration-nextjs": "^0.14.4",
    "@auth/core": "^0.41.0",
    "@auth/drizzle-adapter": "^1.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@envelop/depth-limit": "^7.1.1",
    "@neondatabase/serverless": "^1.0.2",
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-drizzle": "^0.17.0",
    "@pothos/plugin-scope-auth": "^4.1.6",
    "@sweptmind/native-bridge": "file:packages/native-bridge",
    "@vercel/blob": "^2.3.1",
    "apollo3-cache-persist": "^0.15.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dataloader": "^2.2.3",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "firebase-admin": "^13.7.0",
    "graphql": "^16.13.0",
    "graphql-yoga": "^5.18.0",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pg": "^8.19.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-resizable-panels": "^4.7.2",
    "rxjs": "^7.8.2",
    "serwist": "^9.5.6",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor-community/contacts": "^7.1.0",
    "@graphql-codegen/cli": "^6.1.2",
    "@graphql-codegen/typescript": "^5.0.8",
    "@graphql-codegen/typescript-operations": "^5.0.8",
    "@playwright/test": "^1.58.2",
    "@serwist/turbopack": "^9.5.6",
    "@sweptmind/capacitor-geofence": "file:packages/capacitor-geofence",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsdom": "^28",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
