{
  "name": "sweptmind-cli",
  "version": "0.3.1",
  "description": "CLI tool for SweptMind task management",
  "type": "module",
  "bin": {
    "sm": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/mcp-server.ts --format esm --clean",
    "dev": "tsup src/index.ts src/mcp-server.ts --format esm --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "graphql": "^16.10.0",
    "graphql-request": "^7.1.2",
    "open": "^10.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sweptmind/sweptmind"
  },
  "license": "MIT",
  "keywords": [
    "todo",
    "tasks",
    "gtd",
    "cli",
    "sweptmind"
  ]
}
